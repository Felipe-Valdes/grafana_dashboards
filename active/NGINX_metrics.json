          "showMiniMap": false
        },
        "content": "<div style=\"display: flex; align-items: center; justify-content: center; height: 100%; width: 100%; overflow: hidden;\">\n  <img src=\"https://www.vectorlogo.zone/logos/nginx/nginx-ar21.svg\" style=\"height: 85%; width: auto; object-fit: contain;\" />\n</div>",
        "mode": "html"
      },
      "pluginVersion": "12.3.2",
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "description": "- **Definición**: Tasa de conexiones aceptadas por el socket pero que no fueron manejadas por un worker process por segundo.\n- **Interpretación**: Un valor mayor a 0 indica saturación. Generalmente ocurre cuando se alcanza el límite de `worker_connections` en Nginx o el límite de descriptores de archivos del SO.\n- **Valores esperados**: Debe ser estrictamente 0. Cualquier incremento indica pérdida de tráfico y latencia para los usuarios.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "#F2495C",
            "mode": "fixed"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "area",
            "hideFrom": {
              "legend": true,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 0.0001
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 12,
        "w": 10,
        "x": 4,
        "y": 1
      },
      "id": 201,
