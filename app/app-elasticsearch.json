        },
        "content": "<div style=\"display: flex; align-items: center; justify-content: center; height: 100%; width: 100%; overflow: hidden;\">\n  <img src=\"https://www.vectorlogo.zone/logos/elastic/elastic-ar21.svg\" style=\"height: 85%; width: auto; object-fit: contain;\" />\n</div>",
